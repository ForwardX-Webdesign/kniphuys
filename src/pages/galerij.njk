---
layout: layouts/base.njk
title: Galerij
permalink: /galerij/
extraStyles: |
  <style>
    .galerij-page__hero {
      padding: 140px 0 56px;
      background: var(--dark);
      text-align: center;
    }
    .galerij-page__hero .eyebrow { color: var(--beige-dark); }
    .galerij-page__hero h1 {
      font-family: var(--font-heading);
      font-size: clamp(40px, 5vw, 64px);
      font-weight: 600;
      color: var(--white);
      line-height: 1.1;
      margin-bottom: 16px;
    }
    .galerij-page__hero p {
      font-size: 15px;
      color: rgba(255,255,255,0.6);
      max-width: 480px;
      margin: 0 auto;
    }

    /* Filter buttons */
    .galerij-filters {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: center;
      padding: 40px 24px 32px;
      background: var(--beige-light);
      border-bottom: 1px solid var(--beige-medium);
    }
    .galerij-filter {
      font-family: var(--font-body);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      padding: 10px 22px;
      border: 1.5px solid var(--beige-dark);
      border-radius: 2px;
      background: transparent;
      color: var(--text);
      cursor: pointer;
      transition: background .2s, color .2s, border-color .2s;
    }
    .galerij-filter:hover { border-color: var(--primary); color: var(--primary); }
    .galerij-filter.active {
      background: var(--primary);
      border-color: var(--primary);
      color: var(--white);
    }

    /* Grid */
    .galerij-page__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 5px;
      padding: 5px;
      background: var(--beige-light);
    }
    .g-item {
      position: relative;
      overflow: hidden;
      cursor: pointer;
      background: var(--beige-medium);
      aspect-ratio: 1 / 1;
      transition: opacity .4s, transform .4s;
    }
    .g-item.hidden {
      display: none;
    }
    .g-item img {
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
      transition: transform .5s ease;
    }
    .g-item:hover img { transform: scale(1.05); }

    /* Video item */
    .g-item--video video {
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
    }
    .g-item--video::after {
      content: '▶';
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 36px;
      color: rgba(255,255,255,0.9);
      background: rgba(20,10,2,0.35);
      pointer-events: none;
    }

    /* Wide / tall variants */
    .g-item--wide { grid-column: span 2; aspect-ratio: 2 / 1; }
    .g-item--tall { grid-row: span 2; aspect-ratio: unset; }
    .g-item--tall img { height: 100%; }

    /* Lightbox */
    .lightbox {
      position: fixed; inset: 0; z-index: 500;
      background: rgba(10,5,0,0.93);
      display: flex; align-items: center; justify-content: center;
      opacity: 0; pointer-events: none;
      transition: opacity .3s;
      padding: 24px;
    }
    .lightbox.active { opacity: 1; pointer-events: all; }
    .lightbox img {
      max-width: 90vw; max-height: 88vh;
      object-fit: contain;
      border-radius: 2px;
      box-shadow: 0 32px 80px rgba(0,0,0,0.6);
    }
    .lightbox__close {
      position: absolute; top: 20px; right: 24px;
      background: none; border: none; cursor: pointer;
      color: rgba(255,255,255,0.7); font-size: 28px; line-height: 1;
      transition: color .2s;
    }
    .lightbox__close:hover { color: var(--white); }
    .lightbox__prev, .lightbox__next {
      position: absolute; top: 50%; transform: translateY(-50%);
      background: rgba(255,255,255,0.1); border: none; cursor: pointer;
      color: var(--white); font-size: 28px; width: 52px; height: 52px;
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      transition: background .2s;
    }
    .lightbox__prev:hover, .lightbox__next:hover { background: rgba(255,255,255,0.25); }
    .lightbox__prev { left: 16px; }
    .lightbox__next { right: 16px; }

    @media (max-width: 767px) {
      .galerij-page__grid { grid-template-columns: repeat(2, 1fr); }
      .g-item--wide { grid-column: span 1; aspect-ratio: 1 / 1; }
      .g-item--tall { grid-row: span 1; aspect-ratio: 1 / 1; }
      .g-item--tall img { height: 100%; }
    }
    @media (max-width: 480px) {
      .galerij-page__grid { grid-template-columns: 1fr; }
    }
  </style>
extraScripts: |
  <script>
  // Filter
  const filterBtns = document.querySelectorAll('.galerij-filter');
  const gItems = document.querySelectorAll('.g-item');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const f = btn.dataset.filter;
      gItems.forEach(item => {
        const match = f === 'alles' || item.dataset.cat === f;
        item.classList.toggle('hidden', !match);
      });
      buildLightIndex();
    });
  });

  // Video hover play
  document.querySelectorAll('.g-item--video video').forEach(v => {
    v.closest('.g-item').addEventListener('mouseenter', () => v.play());
    v.closest('.g-item').addEventListener('mouseleave', () => v.pause());
  });

  // Lightbox
  let lightItems = [];
  let lightCurrent = 0;
  const lightbox = document.getElementById('lightbox');
  const lightImg = document.getElementById('lightbox-img');

  function buildLightIndex() {
    lightItems = Array.from(document.querySelectorAll('.g-item:not(.hidden):not(.g-item--video) img'));
  }
  buildLightIndex();

  function openLight(el) {
    const img = el.querySelector('img');
    if (!img) return;
    buildLightIndex();
    lightCurrent = lightItems.indexOf(img);
    lightImg.src = img.src;
    lightImg.alt = img.alt;
    lightbox.classList.add('active');
    document.body.style.overflow = 'hidden';
  }
  function closeLight() {
    lightbox.classList.remove('active');
    document.body.style.overflow = '';
  }
  function lightStep(dir) {
    if (!lightItems.length) return;
    lightCurrent = (lightCurrent + dir + lightItems.length) % lightItems.length;
    lightImg.src = lightItems[lightCurrent].src;
    lightImg.alt = lightItems[lightCurrent].alt;
  }
  document.addEventListener('keydown', e => {
    if (!lightbox.classList.contains('active')) return;
    if (e.key === 'Escape') closeLight();
    if (e.key === 'ArrowLeft') lightStep(-1);
    if (e.key === 'ArrowRight') lightStep(1);
  });
  </script>
---

