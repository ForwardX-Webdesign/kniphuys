---
layout: layouts/base.njk
title: Merken
permalink: /merken/
extraStyles: |
  <style>
    .merken-hero {
      padding: 140px 0 60px;
      background: var(--dark);
      text-align: center;
    }
    .merken-hero .eyebrow { color: var(--beige-dark); }
    .merken-hero h1 {
      font-family: var(--font-heading);
      font-size: clamp(40px, 5vw, 64px);
      font-weight: 600;
      color: var(--white);
      line-height: 1.1;
      margin-bottom: 16px;
    }
    .merken-hero p {
      font-size: 15px;
      color: rgba(255,255,255,0.6);
      max-width: 520px;
      margin: 0 auto;
    }

    .merken-section {
      background: var(--beige-light);
      padding: 72px 0 88px;
    }

    .merken-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 28px;
      margin-top: 0;
    }

    .merk-card {
      background: var(--white);
      border: 1px solid var(--beige-medium);
      border-radius: 4px;
      padding: 48px 44px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      transition: box-shadow .25s, border-color .25s;
    }
    .merk-card:hover {
      box-shadow: 0 12px 40px rgba(0,0,0,0.08);
      border-color: var(--beige-dark);
    }

    .merk-card__label {
      font-family: var(--font-body);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--primary);
    }

    .merk-card__name {
      font-family: var(--font-heading);
      font-size: clamp(32px, 4vw, 48px);
      font-weight: 600;
      color: var(--dark);
      line-height: 1;
      margin: 0;
    }

    .merk-card__divider {
      width: 40px;
      height: 2px;
      background: var(--primary);
      border: none;
      margin: 4px 0;
    }

    .merk-card__desc {
      font-size: 14px;
      line-height: 1.85;
      color: var(--text-light);
      flex: 1;
    }

    .merk-card__link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-body);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--dark);
      text-decoration: none;
      border-bottom: 1.5px solid var(--beige-dark);
      padding-bottom: 3px;
      transition: color .2s, border-color .2s;
      align-self: flex-start;
    }
    .merk-card__link:hover {
      color: var(--primary);
      border-color: var(--primary);
    }
    .merk-card__link svg {
      width: 14px; height: 14px;
      flex-shrink: 0;
    }

    /* SISKO card – accent */
    .merk-card--sisko {
      background: var(--dark);
      border-color: var(--dark);
      color: var(--white);
    }
    .merk-card--sisko .merk-card__name { color: var(--white); }
    .merk-card--sisko .merk-card__desc { color: rgba(255,255,255,0.65); }
    .merk-card--sisko .merk-card__link {
      color: var(--beige-dark);
      border-color: rgba(200,170,125,0.4);
    }
    .merk-card--sisko .merk-card__link:hover {
      color: var(--white);
      border-color: var(--white);
    }
    .merk-card--sisko .merk-card__label { color: var(--beige-dark); }

    @media (max-width: 767px) {
      .merken-grid { grid-template-columns: 1fr; gap: 16px; }
      .merk-card { padding: 36px 28px; }
    }
  </style>
---

<!-- ═══ HERO ═══ -->
<section class="merken-hero">
  <div class="container">
    <p class="eyebrow">Onze partners</p>
    <h1>Merken</h1>
    <p>Wij werken uitsluitend met professionele merken die passen bij onze kwaliteitsstandaard – voor het beste resultaat voor jouw haar.</p>
  </div>
</section>

<!-- ═══ MERKEN GRID ═══ -->
<section class="merken-section">
  <div class="container">
    <div class="merken-grid">

      <!-- Davines -->
      <div class="merk-card">
        <span class="merk-card__label">Haarverzorging</span>
        <h2 class="merk-card__name">Davines</h2>
        <hr class="merk-card__divider" />
        <p class="merk-card__desc">Davines is een Italiaans professioneel haarverzorgingsmerk dat duurzaamheid combineert met topprestaties. Hun producten zijn ontwikkeld voor professioneel gebruik in de salon en staan bekend om rijke ingrediënten en prachtige resultaten.</p>
        <a class="merk-card__link" href="https://www.davines.com/nl/" target="_blank" rel="noopener">
          Bezoek davines.com
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
        </a>
      </div>

      <!-- Wella -->
      <div class="merk-card">
        <span class="merk-card__label">Kleur &amp; Styling</span>
        <h2 class="merk-card__name">Wella</h2>
        <hr class="merk-card__divider" />
        <p class="merk-card__desc">Wella Professionals is wereldwijd toonaangevend in professionele haarkleur en stylingproducten. Met decennia aan innovatie biedt Wella de kleurmiddelen en verzorgingslijnen die wij gebruiken voor langdurig en prachtig resultaat.</p>
        <a class="merk-card__link" href="https://www.wella.com/nl-NL/" target="_blank" rel="noopener">
          Bezoek wella.com
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
        </a>
      </div>

      <!-- LookX -->
      <div class="merk-card">
        <span class="merk-card__label">Make-up &amp; Huidverzorging</span>
        <h2 class="merk-card__name">LookX</h2>
        <hr class="merk-card__divider" />
        <p class="merk-card__desc">LookX is een professioneel make-upmerk dat beauty en verzorging combineert. Naast een mooie finish biedt LookX ook huidverzorgende eigenschappen – ideaal voor onze bruidsstyling en speciale gelegenheden.</p>
        <a class="merk-card__link" href="https://www.lookx.nl/" target="_blank" rel="noopener">
          Bezoek lookx.nl
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
        </a>
      </div>

      <!-- SISKO Hair -->
      <div class="merk-card merk-card--sisko">
        <span class="merk-card__label">Natural Hairweaves</span>
        <h2 class="merk-card__name">SISKO Hair</h2>
        <hr class="merk-card__divider" />
        <p class="merk-card__desc">SISKO Hair is ons eigen ontwikkelde merk voor natural hairweaves van topkwaliteit. Speciaal samengesteld voor een natuurlijk resultaat dat past bij jouw haar – vakkundig aangebracht door onze gecertificeerde stylisten.</p>
        <a class="merk-card__link" href="https://siskohair.nl/" target="_blank" rel="noopener">
          Bezoek siskohair.nl
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
        </a>
      </div>

    </div>
  </div>
</section>
