<!-- ═══ FAQ ═══ -->
<section class="faq">
  <div class="container">
    <div class="faq__head">
      <span class="section-label">Veel gestelde vragen</span>
      <h2 class="section-heading section-heading--center">Alles wat je wil weten</h2>
    </div>
    <div class="faq__list">
      <div class="faq-item">
        <button class="faq-item__question" onclick="toggleFaq(this)">
          Wat zijn SISKO Hairweaves precies?
          <span class="faq-item__icon">+</span>
        </button>
        <div class="faq-item__answer">
          <p>SISKO Hairweaves zijn een onzichtbare methode om haar te verlengen of volume toe te voegen. Ze worden gemaakt van 100% Remy Human Hair en aangebracht zonder schade aan jouw eigen haar.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-item__question" onclick="toggleFaq(this)">
          Hoe lang duurt een SISKO behandeling?
          <span class="faq-item__icon">+</span>
        </button>
        <div class="faq-item__answer">
          <p>Een eerste plaatsing duurt afhankelijk van het aantal kabeltjes tussen de 1 en 3 uur. We raden aan om eerst een vrijblijvend adviesgesprek in te plannen.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-item__question" onclick="toggleFaq(this)">
          Kan ik ook op zaterdag terecht?
          <span class="faq-item__icon">+</span>
        </button>
        <div class="faq-item__answer">
          <p>Zaterdag zijn wij alleen open op afspraak voor bijzondere gelegenheden zoals bruidskapsels. Neem contact op om de mogelijkheden te bespreken.</p>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-item__question" onclick="toggleFaq(this)">
          Welke merken gebruiken jullie?
          <span class="faq-item__icon">+</span>
        </button>
        <div class="faq-item__answer">
          <p>Wij werken uitsluitend met premium merken zoals Davines en Wella voor kleur, behandelingen en verzorging. Producten zijn ook bij ons te koop.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ CONTACT FORMULIER ═══ -->
<section class="contact-section" id="contact">
  <div class="container">
    <div class="contact-section__grid">

      <div class="contact-section__info">
        <span class="section-label">Bereikbaarheid</span>
        <h2 class="section-heading">Neem contact op</h2>
        <p class="section-sub">Vragen over onze behandelingen of wil je meer weten over SISKO Hairweaves? Stuur ons een bericht en we nemen zo snel mogelijk contact met u op.</p>
        <div class="locatie__items" style="margin-top:32px; display:flex; flex-direction:column; gap:14px;">
          <div class="locatie__item">
            <svg class="locatie__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {{ site.contact.address }}
          </div>
          <div class="locatie__item">
            <svg class="locatie__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012.18 1h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 8.1a16 16 0 006 6l1.46-1.46a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
            <a href="tel:{{ site.contact.phone_href }}" style="color:inherit">{{ site.contact.phone }}</a>
          </div>
          <div class="locatie__item">
            <svg class="locatie__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <a href="mailto:{{ site.contact.email }}" style="color:inherit">{{ site.contact.email }}</a>
          </div>
        </div>
      </div>

      <div class="contact-section__form">
        <form class="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/danku/">
          <input type="hidden" name="form-name" value="contact">
          <div class="hidden"><label>Niet invullen: <input name="bot-field"></label></div>

          <div class="contact-form__row">
            <div class="contact-form__field">
              <label for="naam">Naam</label>
              <input type="text" id="naam" name="naam" placeholder="Uw naam" required>
            </div>
            <div class="contact-form__field">
              <label for="email">E-mailadres</label>
              <input type="email" id="email" name="email" placeholder="uw@email.nl" required>
            </div>
          </div>

          <div class="contact-form__row">
            <div class="contact-form__field">
              <label for="telefoon">Telefoonnummer</label>
              <input type="tel" id="telefoon" name="telefoon" placeholder="0612 345 678">
            </div>
            <div class="contact-form__field">
              <label for="onderwerp">Onderwerp</label>
              <select id="onderwerp" name="onderwerp">
                <option value="">Selecteer onderwerp</option>
                <option value="Knippen &amp; Styling">Knippen &amp; Styling</option>
                <option value="SISKO Hairweaves">SISKO Hairweaves</option>
                <option value="Bruidskapsels">Bruidskapsels</option>
                <option value="Kleurbehandeling">Kleurbehandeling</option>
                <option value="Overig">Overig</option>
              </select>
            </div>
          </div>

          <div class="contact-form__field">
            <label for="bericht">Bericht</label>
            <textarea id="bericht" name="bericht" rows="5" placeholder="Uw vraag of opmerking..." required></textarea>
          </div>

          <button type="submit" class="btn btn--primary" style="align-self:flex-start">Verstuur bericht →</button>
        </form>
      </div>

    </div>
  </div>
</section>

