          <a href="mailto:{{ site.contact.email }}" style="color:inherit">{{ site.contact.email }}</a>
        </div>
        <div class="locatie__item">
          <svg class="locatie__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          <a href="https://instagram.com/{{ site.social.instagram }}" target="_blank" style="color:inherit">@{{ site.social.instagram }}</a>
        </div>
        <div style="margin-top:28px">
          <a class="btn btn--primary" href="{{ site.booking_url }}" target="_blank">Afspraak Maken</a>
        </div>
      </div>
    </div>
  </div>
</section>

